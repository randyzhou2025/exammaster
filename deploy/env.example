# 复制为仓库根目录的 .env.prod（不要提交 git），与 docker-compose.prod.yml 配套使用
#
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

EXAM_POSTGRES_PASSWORD=请改为强密码
JWT_SECRET=请改为至少16字符的随机串
JWT_EXPIRES_IN=7d

# 可选：首次启动 API 时若该邮箱不存在则创建管理员
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=YourSecurePassword
