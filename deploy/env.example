# 复制为仓库根目录的 .env.prod（不要提交 git），与 docker-compose.prod.yml 配套使用
#
# docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build
#
# 更新数据库表结构（在仓库根目录执行，勿在 server/ 裸跑 db:push，需容器内 DATABASE_URL）：
#   npm run db:push:prod
# 或：
#   docker compose -f docker-compose.prod.yml --env-file .env.prod exec exam_api npm run db:push

EXAM_POSTGRES_PASSWORD=请改为强密码
JWT_SECRET=请改为至少16字符的随机串
JWT_EXPIRES_IN=7d

# 可选：首次启动 API 时若该邮箱不存在则创建管理员
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=YourSecurePassword

# 宝塔等「子路径」部署（如 https://qiway.site/examprep/）时必填，并与外层 Nginx 一致：
# VITE_BASE_PATH=/examprep/
# 根域名部署省略此项或写 VITE_BASE_PATH=/
