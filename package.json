{
  "name": "ai-trainer-exam-prototype",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "setup:local": "node scripts/setup-local.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "db:push": "npm --prefix server run db:push",
    "db:push:prod": "docker compose -f docker-compose.prod.yml --env-file .env.prod exec exam_api npm run db:push",
    "dev": "vite",
    "dev:api": "npm --prefix server run dev",
    "dev:full": "concurrently -k -n bank,web,api -c yellow,blue,green \"npm run build:code-bank\" \"npm run dev\" \"npm run dev:api\"",
    "build": "node scripts/build-code-fill-bank.mjs && tsc -b && vite build",
    "build:web": "tsc -b && vite build",
    "import-theory-bank": "npm --prefix scripts run import-theory-bank",
    "import-theory-bank-l4": "npm --prefix scripts run import-theory-bank-l4",
    "generate-theory-bank-pdf": "npm --prefix scripts run generate-theory-bank-pdf",
    "mobile-shot": "npm --prefix scripts run mobile-shot",
    "build:code-bank": "node scripts/build-code-fill-bank.mjs",
    "preview": "vite preview",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml --env-file .env.prod down",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml --env-file .env.prod logs -f --tail=80"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.3",
    "vite": "^5.4.11"
  }
}
