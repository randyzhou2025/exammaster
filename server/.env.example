# PostgreSQL 连接串（示例）
# 若使用仓库根目录 docker-compose.yml，本地为：
# DATABASE_URL=postgresql://exam:exam_dev_password@127.0.0.1:5433/exam_master
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/exam_master

# JWT 签名密钥（至少 16 字符，生产环境务必随机生成）
JWT_SECRET=change-me-to-a-long-random-string

# 可选：默认 7d
# JWT_EXPIRES_IN=7d

# API 监听
# PORT=4000
# HOST=0.0.0.0

# 首次启动自动创建管理员（仅当该邮箱尚不存在时）
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=your-secure-password
